<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Header Gradient -->
        <View
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_admin_header"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:text="Admin Dashboard"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time Analytics"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="@id/tvAdminTitle"
            app:layout_constraintTop_toBottomOf="@id/tvAdminTitle" />

        <!-- Stats Cards Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-60dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/headerBg">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:padding="8dp"
                android:rowCount="2">

                <!-- Total Orders -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_search_view"
                    android:backgroundTint="#F8F9FE"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconTotal"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="#E8EAFF"
                        android:padding="8dp"
                        android:src="@drawable/ic_cart"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/admin_blue" />

                    <TextView
                        android:id="@+id/totalOrdersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconTotal"
                        app:layout_constraintTop_toTopOf="@id/iconTotal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Orders"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/totalOrdersCount"
                        app:layout_constraintTop_toBottomOf="@id/totalOrdersCount" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Active Orders -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_search_view"
                    android:backgroundTint="#F8F9FE"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconActive"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="#FFF1ED"
                        android:padding="8dp"
                        android:src="@drawable/ic_history"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/admin_orange" />

                    <TextView
                        android:id="@+id/activeOrdersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconActive"
                        app:layout_constraintTop_toTopOf="@id/iconActive" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Orders"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/activeOrdersCount"
                        app:layout_constraintTop_toBottomOf="@id/activeOrdersCount" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Delivered -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_search_view"
                    android:backgroundTint="#F8F9FE"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconDelivered"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="#E6FFED"
                        android:padding="8dp"
                        android:src="@drawable/ic_success_24"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/admin_green" />

                    <TextView
                        android:id="@+id/deliveredOrdersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconDelivered"
                        app:layout_constraintTop_toTopOf="@id/iconDelivered" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivered"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/deliveredOrdersCount"
                        app:layout_constraintTop_toBottomOf="@id/deliveredOrdersCount" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Total Users -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_search_view"
                    android:backgroundTint="#F8F9FE"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconUsers"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="#F2EDFF"
                        android:padding="8dp"
                        android:src="@drawable/ic_user"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/admin_purple" />

                    <TextView
                        android:id="@+id/totalUsersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="0"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconUsers"
                        app:layout_constraintTop_toTopOf="@id/iconUsers" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Users"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/totalUsersCount"
                        app:layout_constraintTop_toBottomOf="@id/totalUsersCount" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Driver Summary -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/driverCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/statsContainer">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <ImageView
                    android:id="@+id/icDriver"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#F6F9FF"
                    android:padding="8dp"
                    android:src="@drawable/ic_user"
                    app:tint="#5E72E4" />
                <TextView
                    android:id="@+id/activeDriversCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/icDriver"
                    android:text="0"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/activeDriversCount"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/icDriver"
                    android:text="Active Drivers"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/onlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="● 0 Online Now"
                    android:textColor="#5E72E4"
                    android:textStyle="bold" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Financial Summary -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/revenueCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/driverCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Revenue"
                    android:textSize="14sp"
                    android:textColor="@color/foody_gray"/>
                <TextView
                    android:id="@+id/tvRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 MAD"
                    android:textColor="@color/foody_orange"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI: Order Trends (LineChart) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chartCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/revenueCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order Trends (Last 7 Days)"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/orderChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI: Revenue Breakdown (BarChart) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chartCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/chartCard1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Revenue (Last 7 Days)"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/revenueBarChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI: Status Distribution (PieChart) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chartCard3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/chartCard2">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order Status Distribution"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/statusPieChart"
                    android:layout_width="match_parent"
                    android:layout_height="250dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KPI: Top Selling Items (Horizontal BarChart) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chartCard4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/chartCard3">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Selling Items"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>
                <com.github.mikephil.charting.charts.HorizontalBarChart
                    android:id="@+id/topMealsChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Actions -->
        <LinearLayout
            android:id="@+id/actionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/chartCard4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageOrders"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FF6B5A"
                android:text="Manage All Orders"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_history"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageDrivers"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#5E72E4"
                android:text="Manage Delivery Drivers"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_user"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageUsers"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#8965E0"
                android:text="Manage Registered Users"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_user"
                app:iconGravity="textStart" />
        </LinearLayout>

        <!-- Hidden placeholder -->
        <TextView android:id="@+id/totalRevenue" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>